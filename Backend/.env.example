# Backend environment variables
# Render will provide its own PORT value.
PORT=3000

# MongoDB connection string (required).
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/database

# Secrets and keys
JWT_SECRET=replace-with-strong-secret
GOOGLE_GENAI_API_KEY=replace-with-google-genai-key

# Comma-separated list of allowed origins for CORS.
# Example for local dev: http://localhost:5173,http://localhost:4173
# When deploying set this to your Vercel app URL(s) (e.g., https://my-app.vercel.app).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
